# General settings
HD_BASE_URL="http://localhost"
HD_INTERNAL_API_URL="http://backend:3000"
HD_BACKEND_BIND_IP="0.0.0.0"
HD_AUTH_SESSION_SECRET="dev-secret-must-be-at-least-thirty-two-characters-long"

# Database settings
HD_DATABASE_TYPE="postgres"
HD_DATABASE_HOST="db"
HD_DATABASE_PORT="5432"
HD_DATABASE_NAME="hedgedoc"
HD_DATABASE_USERNAME="hedgedoc"
HD_DATABASE_PASSWORD="password"

# Uploads
HD_MEDIA_BACKEND_TYPE="filesystem"
HD_MEDIA_BACKEND_FILESYSTEM_UPLOAD_PATH="uploads/"

# Auth
HD_AUTH_LOCAL_ENABLE_LOGIN="true"
HD_AUTH_LOCAL_ENABLE_REGISTER="true"
HD_AUTH_LOCAL_MINIMAL_PASSWORD_STRENGTH="0"

# Note Permissions
HD_NOTE_PERMISSIONS_MAX_GUEST_LEVEL="write"
HD_NOTE_PERMISSIONS_DEFAULT_EVERYONE="read"
